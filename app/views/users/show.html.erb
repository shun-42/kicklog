<div class="container py-5">
  <div class="card p-4 shadow-sm mb-4">
    <h2 class="mb-3">マイページ</h2>
    <p><strong>ニックネーム:</strong> <%= @user.nickname %></p>
    <p><strong>登録メールアドレス:</strong> <%= @user.email %></p>
    <p><strong>ポジション:</strong> <%= @user.position %></p>
    
    <% if @user == current_user %>
      <%= link_to "プロフィールを編集", edit_user_path(@user), class: "btn btn-outline-success" %>
    <% end %>
    <%= link_to "ホームに戻る", root_path, class: "btn btn-outline-secondary" %>
  </div>
  <% if @user == current_user %>
    <div class="mt-5 text-center">
      <%= button_to '退会する', destroy_account_user_path(@user), 
          method: :delete, 
          onclick: "if(!confirm('本当に退会してもよろしいですか？')) return false;", 
          form: { data: { turbo: false } }, 
          class: 'btn btn-danger' %>
    </div>
  <% end %>

  <h2 class="mb-3">投稿一覧</h2>
  <% @posts.each do |post| %>
    <div class="card p-3 mb-3 shadow-sm">
      <% if post.image.attached? %>
        <%= image_tag post.image, size: "180x150", class: "mb-2" %>
      <% end %>

      <h5><%= post.spike_name %></h5>
      <p><%= post.content %></p>

      <%# 項目定義（詳細画面と同じ！） %>
      <% items = [
        { key: "trap", label: "トラップ" },
        { key: "kick", label: "キック" },
        { key: "sprint", label: "スプリント" },
        { key: "pass_accuracy", label: "パス精度" },
        { key: "durability", label: "耐久性" }
      ] %>

      <div class="row">
        <% items.each do |item| %>
          <div class="col-md-2">
            <small><%= item[:label] %></small>
            <%# ★重要：IDに post.id を含めて個別に指定 %>
            <div id="star-<%= item[:key] %>-<%= post.id %>"></div>
          </div>
        <% end %>
      </div>

      <script>
        $(function() {
          <% items.each do |item| %>
            $('#star-<%= item[:key] %>-<%= post.id %>').raty({
              size: 16,
              starOff: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-off.png',
              starOn: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-on.png',
              // ここを修正！post.send(item[:key]) で直接カラムの値を取得します
              score: <%= post.send(item[:key]) || 0 %>,
              readOnly: true
            });
          <% end %>
        });
      </script>

      <div class="mt-2">
        <%= link_to "詳細を見る", post_path(post), class: "btn btn-sm btn-success" %>
      </div>
    </div>
  <% end %>
</div>