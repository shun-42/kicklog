<div class="container py-5">
  <h2>投稿詳細</h2>
  <div class="card p-4">
    <% if @post.image.attached? %>
     <%= image_tag @post.image, class: "img-fluid rounded mx-auto d-block", style: "max-width: 400px;" %>
    <% end %>
    <h4 class="mt-3">ブランド: <%= @post.brand.name %></h4>
    <h4 class="mt-3">スパイク: <%= @post.spike_name %></h4>
    <p>内容: <%= @post.content %></p>
    <div class="row mt-4">
      <%# 各項目を定義 %>
      <% items = [
        { key: "trap", label: "トラップのしやすさ（クッション性）" },
        { key: "kick", label: "キック精度（シュート・ロングフィード等）" },
        { key: "sprint", label: "スプリント（走りやすさ）" },
        { key: "pass_accuracy", label: "パス精度" },
        { key: "durability", label: "耐久性・疲れにくさ" }
      ] %>
      
      <% items.each do |item| %>
        <div class="col-md-4 mb-3">
          <label><%= item[:label] %></label>
          <div id="star-<%= item[:key] %>"></div>
        </div>

        <script>
          $(function() {
            $('#star-<%= item[:key] %>').raty({
              size: 36,
              starOff: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-off.png',
              starOn: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-on.png',
              // ここでRubyの値をJavaScriptに埋め込む
              score: <%= @post.send(item[:key]) || 0 %>,
              readOnly: true
            });
          });
        </script>
      <% end %>
    </div>
  </div>
  <h3>コメント</h3>
  <% @post.post_comments.each do |post_comment| %>
    <p><%= post_comment.user.nickname %>: <%= post_comment.comment %></p>
    <% if post_comment.user == current_user %>
      <%= button_to '削除', post_post_comment_path(@post, post_comment), method: :delete, onclick: "if(!confirm('本当に削除しますか？')) return false;", class: "btn btn-danger" %>
    <% end %>
  <% end %>

  <%# コメント投稿フォーム %>
  <div class="mt-4">
    <%= form_with model: [@post, PostComment.new], local: true do |f| %>
      <%= f.text_area :comment, placeholder: "コメントを入力...", class: "form-control" %>
      <%= f.submit "送信", class: "btn btn-success mt-2" %>
    <% end %>
  </div>
  <div class="mt-3">
    <%= link_to '戻る', brand_posts_path(@post.brand_id), class: 'btn btn-secondary', data: { turbo: false } %>
  </div>
</div>