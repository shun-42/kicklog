<div class="container py-5">
  <h2><%= @brand.name %> について投稿</h2>

  <% if @post.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: [@brand, @post], local: true) do |f| %>
    <div class="form-group mt-3">
      <%= f.label :spike_name, "スパイクの名前" %>
      <%= f.text_field :spike_name, class: "form-control", placeholder: "スパイク名を入力" %>
    </div>

    <div class="form-group mt-3">
      <%= f.label :content, "感想" %>
      <%= f.text_area :content, class: "form-control", placeholder: "感想を入力" %>
    </div>

    <div class="form-group mt-3">
      <%= f.label :image, "写真" %>
      <%= f.file_field :image, class: "form-control" %>
    </div>

    <%= f.submit "投稿する", class: "btn btn-primary mt-3" %>
  <% end %>

  <%= link_to "メーカー選択へ戻る", brands_path, class: "text-muted mt-3 d-block" %>
</div>