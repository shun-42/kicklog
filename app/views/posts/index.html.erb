<h1><%= @brand.name %> の投稿一覧</h1>

<div class="bg-light p-3 mb-4 rounded shadow-sm">
  <%= form_with url: search_posts_path, method: :get, local: true do |f| %>
    
    <%# 1. カテゴリー選択（これは f. の外でOK） %>
    <%= select_tag :category_temp, options_for_select([["ポジションで検索", "position"], ["スタイルで検索", "play_style"]]), id: "category-select" %>
    
    <%# 2. サーバーに送る category 値 %>
    <%= f.hidden_field :category, value: "position", id: "category-hidden" %>

    <%# 3. 検索内容（name属性を 'content' に統一） %>
    <%= f.select :content, ["GK", "DF", "MF", "FW"], { include_blank: "選択してください" }, { id: "position-select", class: "search-content" } %>
    <%= f.select :content, ["ストライカー", "ターゲットマン", "ドリブラー", "パサー", "デュエル", "ビルドアップ", "オーバーラップ", "セービング", "未定"], { include_blank: "選択してください" }, { id: "style-select", class: "search-content", style: "display: none;" } %>

    <%= f.hidden_field :method, value: "perfect" %>
    <%= f.submit "検索" %>
  <% end %>
</div>

<div class="d-flex gap-3 mb-4">
  <%= link_to "このブランドに投稿する", new_brand_post_path(@brand), class: "btn btn-primary px-4 fw-bold", style: "min-width: 180px;" %>
  <%= link_to "ブランド選択へ戻る", brands_path, class: "btn text-white fw-bold px-4", style: "background-color: #d90429; min-width: 180px;" %>
</div>
<% @posts.each do |post| %>
  <div class="card mb-3 mt-3">
    <div class="card-body">

      <% if post.image.attached? %>
        <div class="mb-2">
          <%= image_tag post.image, class: "img-fluid", style: "max-width: 300px; height: auto;" %>
        </div>
      <% end %>

      <h5 class="card-title">スパイク: <%= post.spike_name %></h5>
      <%# 投稿内容 %>
      <p><%= post.content %></p>
      
      <div class="border-top pt-2 mt-2 text-muted">
        <small>
          投稿者: <%= post.user.nickname %> （ポジション: <%= post.user.position %>  プレースタイル:<%= post.user.play_style %>)
        </small>

        <div class="mt-2">
          <%= link_to "詳細を見る", post_path(post), class: "btn", style: "background-color: #356351; color: #ffffff;" %>
        </div>

        <% if post.user == current_user %>
          <div class="mt-2">
            <%# 編集ボタンを修正 %>
            <%= link_to "編集", edit_post_path(post), class: "btn btn-sm btn-outline-secondary" %>
            
            <%= button_to '削除する', post_path(post), method: :delete, 
              onclick: "if(!confirm('本当に削除してもよろしいですか？')) return false;", 
              class: "btn btn-sm btn-outline-danger" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
<div class="text-center mt-5 mb-4">
  <%= link_to "トップページに戻る", root_path, class: "btn text-white fw-bold px-4", style: "background-color: #2d6a4f; min-width: 180px;" %>
</div>

<script>
  document.getElementById('category-select').addEventListener('change', function() {
    const val = this.value;
    const posSelect = document.getElementById('position-select');
    const styleSelect = document.getElementById('style-select');
    
    document.getElementById('category-hidden').value = val;
    
    // 表示切替と無効化（disabled）の切り替え
    if (val === 'position') {
      posSelect.style.display = 'inline-block';
      posSelect.disabled = false; // 有効にする
      styleSelect.style.display = 'none';
      styleSelect.disabled = true;  // 無効にする（送信されない）
    } else {
      posSelect.style.display = 'none';
      posSelect.disabled = true;    // 無効にする（送信されない）
      styleSelect.style.display = 'inline-block';
      styleSelect.disabled = false; // 有効にする
    }
  });

  // ページ読み込み時の初期状態をセット
  document.getElementById('category-select').dispatchEvent(new Event('change'));
</script>