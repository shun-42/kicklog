<div class="container py-5">
  <h2 class="mb-4">投稿・閲覧したいメーカーを選択してください</h2>
  
  <div class="row">
    <% @brands.each do |brand| %>
      <div class="col-md-4">
        <%# メーカーごとの背景色を決定 %>
        <% bg_color = case brand.name
                      when "Water Field" then "bg-primary"
                      when "victory" then "bg-warning"
                      else "bg-light"
                      end %>
        
        <div class="card p-3 mb-3 <%= bg_color %>">
          <%# 文字を太く黒くするために font-weight-bold と text-dark を追加 %>
          <%= link_to brand.name, brand_posts_path(brand), class: "fw-bold text-dark text-decoration-none" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 画面下方にロゴを設置（パスは実際のロゴ画像の名前に合わせてください） %>
  <div class="text-center mt-5">
    <%= image_tag 'kicklog_logo.png', alt: 'Big Logo', style: 'max-width: 300px;' %>
  </div>
</div>
<div class="text-center mt-5 mb-4">
  <%= link_to "トップページに戻る", root_path, class: "btn text-white fw-bold px-4", style: "background-color: #2d6a4f; min-width: 180px;" %>
</div>