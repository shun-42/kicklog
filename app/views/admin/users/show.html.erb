<h1><%= @user.nickname %>さんの詳細</h1>
<p>名前: <%= @user.nickname %></p>
<p>メール: <%= @user.email %></p>

<%= link_to "編集する", edit_admin_user_path(@user) %>
<%= button_to '削除する', admin_user_path(@user), method: :delete, onclick: "if(!confirm('本当に削除しますか？')) return false;", class: "btn btn-danger" %>
<%= link_to "一覧へ戻る", admin_users_path %>