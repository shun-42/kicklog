<div class="container py-5">
  <div class="card p-4 shadow-sm mb-4">
    <h2 class="mb-3"><%= @user.nickname %> さんの詳細</h2>
    <p><strong>ニックネーム:</strong> <%= @user.nickname %></p>
    <p><strong>登録メールアドレス:</strong> <%= @user.email %></p>
    <p><strong>ポジション:</strong> <%= @user.position %></p>

    <%# 管理者用アクション %>
    <div class="mt-3">
      <%= link_to "編集する", edit_admin_user_path(@user), class: "btn btn-primary" %>
      <%= button_to "削除する", admin_user_path(@user), method: :delete, onclick: "return confirm('本当に削除しますか？');", class: "btn btn-danger" %>
  </div>

  <%# 投稿一覧へのリンクセクション %>
  <div class="mt-4">
    <h3>このユーザーの投稿</h3>
    <%= link_to "投稿一覧を表示する", admin_user_posts_path(@user), class: "btn btn-success" %>
  </div>

  <div class="mt-4">
    <%= link_to "ユーザー管理一覧へ戻る", admin_users_path, class: "text-muted" %>
  </div>
</div>