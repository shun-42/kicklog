<div class="container py-5">
  <h2 class="mb-4">ユーザー管理一覧</h2>

  <% @users.each do |user| %>
    <div class="card mb-3 shadow-sm">
      <div class="card-body">
        <div class="row align-items-center">
          <div class="col-md-2">
            <strong>ID: <%= user.id %></strong>
          </div>
          <div class="col-md-3">
            <%= user.nickname %>
          </div>
          <div class="col-md-7 text-md-end">
            <%# ボタンの間隔を gap-2 で調整 %>
            <div class="d-flex justify-content-md-end gap-2">
              <%= link_to "詳細を見る", admin_user_path(user), class: "btn btn-outline-success btn-sm" %>
              <%= link_to "投稿一覧", admin_user_posts_path(user), class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>