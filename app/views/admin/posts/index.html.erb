<div class="container py-5">
  <div class="row">
    <div class="col-md-10 mx-auto">
      <%# ユーザー名のヘッダー %>
      <h2 class="mb-4"><%= @user.nickname %> さんの投稿一覧</h2>

      <%# 投稿がない場合のメッセージ %>
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="card mb-4 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= post.spike_name %></h5>
              <p class="card-text"><%= post.content %></p>
              
              <%# 管理者用アクションボタン %>
              <div class="d-flex gap-2">
                <%= link_to "詳細を見る", admin_user_post_path(@user, post), class: "btn btn-sm btn-success text-white" %>
                <%= link_to "編集する", edit_admin_user_post_path(@user, post), class: "btn btn-sm btn-primary" %>
                <%= button_to "削除する", admin_user_post_path(@user, post), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p>このユーザーにはまだ投稿がありません。</p>
      <% end %>

      <%# 戻るリンク %>
      <div class="mt-4">
        <%= link_to "ユーザー管理一覧に戻る", admin_users_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>