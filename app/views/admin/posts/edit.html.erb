<div class="container py-5">
  <h2>管理者用：投稿を編集する</h2>

  <%# エラーメッセージ表示 %>
  <% if @post.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 変更点：管理者用のURLを指定 %>
  <%= form_with model: @post, url: admin_user_post_path(@post.user, @post), method: :patch, local: true do |f| %>
    <div class="form-group mt-3">
      <%= f.label :spike_name, "スパイクの名前" %>
      <%= f.text_field :spike_name, class: "form-control" %>
    </div>
    
    <div class="form-group mt-3">
      <%= f.label :content, "感想" %>
      <%= f.text_area :content, class: "form-control" %>
    </div>
    
    <div class="form-group mt-3">
      <%= f.label :image, "写真" %>
      <%= f.file_field :image, class: "form-control" %>
    </div>
    
    <%= f.submit "更新する", class: "btn btn-primary mt-3" %>
  <% end %>

  <%# 変更点：戻る先を管理者用の投稿一覧ページへ %>
  <%= link_to "投稿一覧に戻る", admin_user_posts_path(@post.user), class: "text-muted mt-3 d-block" %>
</div>