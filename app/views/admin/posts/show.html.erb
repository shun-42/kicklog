<div class="container py-5">
  <h2>管理者用：投稿詳細</h2>
  <div class="card p-4">
    <% if @post.image.attached? %>
      <%= image_tag @post.image, class: "img-fluid rounded mx-auto d-block", style: "max-width: 400px;" %>
    <% end %>
    <p class="card-text">
      <strong>投稿者:</strong> <%= @post.user&.nickname || "ユーザー不明" %>
    </p>
    <h4 class="mt-3">ブランド: <%= @post.brand.name %></h4>
    <h4 class="mt-3">スパイク: <%= @post.spike_name %></h4>
    <p>内容: <%= @post.content %></p>
    <div class="row mt-4">
      <% items = [
        { key: "trap", label: "トラップのしやすさ（クッション性）" },
        { key: "kick", label: "キック精度（シュート・ロングフィード等）" },
        { key: "sprint", label: "スプリント（走りやすさ）" },
        { key: "pass_accuracy", label: "パス精度" },
        { key: "durability", label: "耐久性・疲れにくさ" }
      ] %>
      
      <% items.each do |item| %>
        <div class="col-md-4 mb-3">
          <strong><%= item[:label] %>:</strong>
          <div id="admin-star-<%= item[:key] %>-<%= @post.id %>"></div>
        </div>

        <script>
          $(function() {
            $('#admin-star-<%= item[:key] %>-<%= @post.id %>').raty({
              size: 36,
              starOff: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-off.png',
              starOn: 'https://cdn.jsdelivr.net/npm/raty-js@2.8.0/lib/images/star-on.png',
              score: <%= @post.send(item[:key]) || 0 %>,
              readOnly: true
            });
          });
        </script>
      <% end %>
    </div>
    <hr>
    
    <%# --- 管理者用の操作エリア --- %>
    <div class="mt-3">
      <%# 編集ボタン：管理者用ルートへ %>
      <%= link_to "投稿を編集する", edit_admin_user_post_path(@post.user, @post), class: "btn btn-primary" %>
      
      <%# 削除ボタン：管理者用ルートへ %>
      <%= button_to "投稿を削除する", admin_user_post_path(@post.user, @post), 
      method: :delete, 
      onclick: "if(!confirm('本当にこの投稿を削除しますか？')) return false;", 
      class: "btn btn-danger" %>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "ユーザーの投稿一覧に戻る", admin_user_posts_path(@post.user), class: "btn btn-secondary" %>
  </div>
</div>